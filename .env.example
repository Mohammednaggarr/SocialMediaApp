# Database
DB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/SocialMediaApp?retryWrites=true&w=majority

# Application
APPLICATION_NAME=social-media
MODE=DEV
PORT=5000

# Email Configuration (Gmail + App Password)
EMAIL=your-gmail@gmail.com
PASSWORD=your-16-char-app-password

# OTP Configuration
OTP_EXPIRATION_MS=600000

# Password Hashing
SALT=10

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
ACCESS_ADMIN_TOKEN_SECRET=
ACCESS_USER_TOKEN_SECRET=
REFRESH_USER_TOKEN_SECRET=
REFRESH_ADMIN_TOKEN_SECRET=

# CORS (comma-separated origins for production)
ALLOWED_ORIGINS=http://localhost:3000

# Token Expiration Times (in milliseconds)
ACCESS_TOKEN_EXPIRATION_MS=3600000
REFRESH_TOKEN_EXPIRATION_MS=604800000

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
